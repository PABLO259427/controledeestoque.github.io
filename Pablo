    <script>
        // Dados do sistema (simulando banco de dados)
        let dados = {
            materiais: [
                {id: 1, codigo: 'MAT001', descricao: 'Cimento Portland 50kg', unidade: 'SC', saldo: 1000, custo: 35.00, localizacao: 'A-01'},
                {id: 2, codigo: 'MAT002', descricao: 'Areia Média', unidade: 'M3', saldo: 500, custo: 80.00, localizacao: 'A-02'},
                {id: 3, codigo: 'MAT003', descricao: 'Brita 1', unidade: 'M3', saldo: 300, custo: 95.00, localizacao: 'A-03'},
                {id: 4, codigo: 'MAT004', descricao: 'Tubo PVC 100mm', unidade: 'UN', saldo: 200, custo: 45.00, localizacao: 'B-01'},
                {id: 5, codigo: 'MAT005', descricao: 'Fio Elétrico 2,5mm', unidade: 'RL', saldo: 150, custo: 120.00, localizacao: 'B-02'}
            ],
            peps: [
                {id: 1, codigo: 'PEP-2024-001', descricao: 'Construção Edifício Alpha', cliente: 'Empresa ABC', responsavel: 'João Silva', status: 'ativo', dataInicio: '2024-01-15', dataFim: '2024-12-30'},
                {id: 2, codigo: 'PEP-2024-002', descricao: 'Reforma Shopping Center', cliente: 'Shopping XYZ', responsavel: 'Maria Santos', status: 'ativo', dataInicio: '2024-02-01', dataFim: '2024-08-15'},
                {id: 3, codigo: 'PEP-2024-003', descricao: 'Instalação Industrial', cliente: 'Indústria 123', responsavel: 'Pedro Costa', status: 'ativo', dataInicio: '2024-03-10', dataFim: '2024-11-20'}
            ],
            movimentacoes: [],
            entradasFornecedor: [],
            entradasDevolucao: [],
            saidas: []
        };

        // Variáveis temporárias
        let tempItensEntradaFornecedor = [];
        let tempItensEntradaDevolucao = [];
        let tempItensSaida = [];
        let movimentacaoAtual = null;

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            inicializarDados();
            atualizarDashboard();
            atualizarListaMateriais();
            atualizarListaPEPs();
            atualizarSelects();
            atualizarUltimasMovimentacoes();
            atualizarEntradasFornecedor();
            atualizarEntradasDevolucao();
            atualizarSaidas();
            atualizarEstoque();
            
            // Data atual no header
            document.getElementById('currentDate').textContent = new Date().toLocaleDateString('pt-BR');
        });

        function inicializarDados() {
            // Gerar algumas movimentações de exemplo
            const now = new Date();
            
            dados.entradasFornecedor.push({
                id: 1,
                data: new Date(now - 86400000 * 2).toISOString(),
                nf: 'NF-001234',
                fornecedor: 'Fornecedor XYZ',
                itens: [
                    {material: dados.materiais[0], qtd: 100, valor: 3500},
                    {material: dados.materiais[1], qtd: 50, valor: 4000}
                ],
                usuario: 'Admin'
            });

            dados.saidas.push({
                id: 1,
                data: new Date(now - 86400000).toISOString(),
                pep: dados.peps[0],
                responsavel: 'João Silva',
                itens: [
                    {material: dados.materiais[0], qtd: 20},
                    {material: dados.materiais[2], qtd: 10}
                ],
                usuario: 'Admin'
            });

            dados.movimentacoes = [
                ...dados.entradasFornecedor.map(e => ({...e, tipo: 'entrada_fornecedor', documento: e.nf})),
                ...dados.saidas.map(s => ({...s, tipo: 'saida_pep', documento: s.pep.codigo}))
            ];
        }

        // Navegação entre seções
        function showSection(sectionId) {
            // Esconder todas as seções
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });
            
            // Mostrar seção selecionada
            document.getElementById(sectionId).classList.add('active');
            
            // Atualizar menu ativo
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
            });
            event.target.closest('.nav-link').classList.add('active');

            // Atualizar dados específicos da seção
            if (sectionId === 'dashboard') atualizarDashboard();
            if (sectionId === 'estoque-total') atualizarEstoque();
        }

        // Alertas
        function showAlert(message, type = 'success') {
            const container = document.getElementById('alertContainer');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type}`;
            
            const icons = {
                success: 'check-circle',
                danger: 'exclamation-circle',
                warning: 'exclamation-triangle'
            };
            
            alert.innerHTML = `<i class="fas fa-${icons[type]}"></i> ${message}`;
            container.appendChild(alert);
            
            setTimeout(() => alert.remove(), 5000);
        }

        // DASHBOARD
        function atualizarDashboard() {
            document.getElementById('totalMateriais').textContent = dados.materiais.length;
            document.getElementById('totalPEPs').textContent = dados.peps.filter(p => p.status === 'ativo').length;
            document.getElementById('totalMovimentacoes').textContent = dados.movimentacoes.filter(m => {
                const hoje = new Date().toDateString();
