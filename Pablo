        function exportarMovimentacao() {
            if (!movimentacaoAtual) return;
            
            let csv = 'Código,Descrição,Unidade,Quantidade\n';
            
            if (movimentacaoAtual.itens) {
                movimentacaoAtual.itens.forEach(item => {
                    csv += `${item.material.codigo},"${item.material.descricao}",${item.material.unidade},${item.qtd}\n`;
                });
            }
            
            const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `movimentacao_${movimentacaoAtual.id || 'export'}_${new Date().toISOString().split('T')[0]}.csv`;
