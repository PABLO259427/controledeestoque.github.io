                div.style.padding = '10px 15px';
                div.style.borderBottom = '1px solid #eee';
                div.innerHTML = `<strong>${mat.codigo}</strong> - ${mat.descricao} (Disp: ${mat.saldo})`;
                div.onclick = () => {
                    document.getElementById('saidaMaterial').value = mat.id;
                    document.getElementById('saidaMaterialSearch').value = `${mat.codigo} - ${mat.descricao}`;
                    document.getElementById('saidaSaldoDisp').value = mat.saldo;
                    results.style.display = 'none';
                };
                results.appendChild(div);
            });
            
            results.style.display = filtrados.length > 0 ? 'block' : 'none';
        }

        function adicionarItemSaida() {
            const materialId = document.getElementById('saidaMaterial').value;
            const qtd = parseFloat(document.getElementById('saidaQtd').value);
            const saldoDisp = parseFloat(document.getElementById('saidaSaldoDisp').value);
            
            if (!materialId || !qtd) {
                showAlert('Selecione o material e informe a quantidade!', 'warning');
                return;
            }
            
            if (qtd > saldoDisp) {
                showAlert('Quantidade maior que o saldo disponível!', 'danger');
                return;
            }
            
            const material = dados.materiais.find(m => m.id == materialId);
            tempItensSaida.push({material, qtd});
            
            atualizarListaItensSaida();
            document.getElementById('saidaMaterial').value = '';
            document.getElementById('saidaMaterialSearch').value = '';
            document.getElementById('saidaQtd').value = '';
            document.getElementById('saidaSaldoDisp').value = '';
        }

        function atualizarListaItensSaida() {
            const container = document.getElementById('listaItensSaida');
            container.innerHTML = '';
            
            tempItensSaida.forEach((item, index) => {
                const div = document.createElement('div');
                div.className = 'item-card';
                div.innerHTML = `
                    <div class="item-info">
                        <h5>${item.material.codigo} - ${item.material.descricao}</h5>
                        <p>Saldo após saída: ${item.material.saldo - item.qtd}</p>
                    </div>
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <div class="item-qtd">
                            <div class="qtd">${item.qtd}</div>
                            <div class="unidade">${item.material.unidade}</div>
                        </div>
                        <button class="btn-icon btn-delete" onclick="removerItemSaida(${index})">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function removerItemSaida(index) {
            tempItensSaida.splice(index, 1);
            atualizarListaItensSaida();
        }

        function salvarSaidaPEP(event) {
            event.preventDefault();
            
            if (tempItensSaida.length === 0) {
                showAlert('Adicione pelo menos um item!', 'warning');
                return;
            }
            
            const pepId = document.getElementById('saidaPEPDestino').value;
            const pep = dados.peps.find(p => p.id == pepId);
            
            const saida = {
                id: Date.now(),
                data: document.getElementById('saidaData').value,
                pep: pep,
                responsavel: document.getElementById('saidaResponsavel').value,
                itens: [...tempItensSaida],
                usuario: 'Admin',
                observacoes: document.getElementById('saidaObs').value
            };
            
            // Atualizar saldo dos materiais
            saida.itens.forEach(item => {
                const mat = dados.materiais.find(m => m.id === item.material.id);
                if (mat) mat.saldo -= item.qtd;
            });
            
            dados.saidas.push(saida);
            dados.movimentacoes.push({...saida, tipo: 'saida_pep', documento: pep.codigo});
            
            tempItensSaida = [];
            atualizarSaidas();
            atualizarUltimasMovimentacoes();
            atualizarEstoque();
            document.getElementById('formSaidaPEP').reset();
            document.getElementById('listaItensSaida').innerHTML = '';
            
            showAlert('Saída registrada com sucesso!');
        }

        function atualizarSaidas() {
            const tbody = document.getElementById('listaSaidas');
            tbody.innerHTML = '';
            
            const saidasOrdenadas = [...dados.saidas].sort((a, b) => 
                new Date(b.data) - new Date(a.data)
            );
            
            saidasOrdenadas.forEach(saida => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${new Date(saida.data).toLocaleString('pt-BR')}</td>
                    <td>${saida.pep.codigo}</td>
                    <td>${saida.responsavel}</td>
                    <td>${saida.itens.length} item(s)</td>
                    <td>${saida.usuario}</td>
                    <td class="action-btns">
                        <button class="btn-icon btn-delete" onclick="excluirSaida(${saida.id})" title="Excluir">
                            <i class="fas fa-trash"></i>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });
        }

        function excluirSaida(id) {
            if (!confirm('Tem certeza que deseja excluir esta saída? O estoque será ajustado.')) return;
            
            const saida = dados.saidas.find(s => s.id === id);
            if (saida) {
                saida.itens.forEach(item => {
                    const mat = dados.materiais.find(m => m.id === item.material.id);
                    if (mat) mat.saldo += item.qtd;
                });
            }
            
            dados.saidas = dados.saidas.filter(s => s.id !== id);
            dados.movimentacoes = dados.movimentacoes.filter(m => m.id !== id);
            
            atualizarSaidas();
            atualizarUltimasMovimentacoes();
            atualizarEstoque();
            showAlert('Saída excluída com sucesso!');
        }

        // ESTOQUE TOTAL
        function atualizarEstoque() {
            const tbody = document.getElementById('listaEstoque');
            tbody.innerHTML = '';
            
            dados.materiais.forEach(mat => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${mat.codigo}</td>
                    <td>${mat.descricao}</td>
                    <td>${mat.unidade}</td>
                    <td>${mat.saldo.toLocaleString('pt-BR')}</td>
                `;
                tbody.appendChild(tr);
            });
        }

        function filtrarEstoque() {
            const termo = document.getElementById('searchEstoque').value.toLowerCase();
            const tbody = document.getElementById('listaEstoque');
            const rows = tbody.getElementsByTagName('tr');
            
            Array.from(rows).forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(termo) ? '' : 'none';
            });
        }

        // CONSULTA POR PEP
        function buscarPEPConsulta(termo) {
            const results = document.getElementById('consultaPEPResults');
            
            if (termo.length < 2) {
                results.style.display = 'none';
                return;
            }
            
            const filtrados = dados.peps.filter(p => 
                p.codigo.toLowerCase().includes(termo.toLowerCase()) ||
                p.descricao.toLowerCase().includes(termo.toLowerCase())
            );
            
            results.innerHTML = '';
            filtrados.forEach(pep => {
                const div = document.createElement('div');
                div.className = 'select-search-item';
                div.style.padding = '10px 15px';
                div.style.borderBottom = '1px solid #eee';
                div.innerHTML = `<strong>${pep.codigo}</strong> - ${pep.descricao}`;
                div.onclick = () => carregarDetalhesPEP(pep.id);
                results.appendChild(div);
            });
            
            results.style.display = filtrados.length > 0 ? 'block' : 'none';
        }

        function carregarDetalhesPEP(pepId) {
            document.getElementById('consultaPEPResults').style.display = 'none';
            const pep = dados.peps.find(p => p.id === pepId);
            
            if (!pep) return;
            
            document.getElementById('consultaPEPDetalhes').style.display = 'block';
            document.getElementById('consultaPEPCodigo').textContent = pep.codigo;
            document.getElementById('consultaPEPCliente').textContent = pep.cliente || '-';
            document.getElementById('consultaPEPResponsavel').textContent = pep.responsavel || '-';
            document.getElementById('consultaPEPStatus').textContent = pep.status === 'ativo' ? 'Ativo' : 'Inativo';
            
            // Calcular materiais alocados
            const materiaisAlocados = {};
            
            // Entradas por devolução (saem do PEP)
            dados.entradasDevolucao.filter(d => d.pep.id === pepId).forEach(dev => {
                dev.itens.forEach(item => {
                    if (!materiaisAlocados[item.material.id]) {
                        materiaisAlocados[item.material.id] = {
                            material: item.material,
                            entregue: 0,
                            devolvido: 0
                        };
                    }
                    materiaisAlocados[item.material.id].devolvido += item.qtd;
                });
            });
            
            // Saídas (entram no PEP)
            dados.saidas.filter(s => s.pep.id === pepId).forEach(saida => {
                saida.itens.forEach(item => {
                    if (!materiaisAlocados[item.material.id]) {
                        materiaisAlocados[item.material.id] = {
                            material: item.material,
                            entregue: 0,
                            devolvido: 0
                        };
                    }
                    materiaisAlocados[item.material.id].entregue += item.qtd;
                });
            });
            
            // Preencher tabela de materiais
            const tbodyMats = document.getElementById('consultaPEPMateriais');
            tbodyMats.innerHTML = '';
            
            Object.values(materiaisAlocados).forEach(item => {
                const saldo = item.entregue - item.devolvido;
                if (saldo > 0) {
                    const tr = document.createElement('tr');
                    tr.innerHTML = `
                        <td>${item.material.codigo}</td>
                        <td>${item.material.descricao}</td>
                        <td>${item.entregue}</td>
                        <td>${item.devolvido}</td>
                        <td><strong>${saldo}</strong></td>
                        <td>-</td>
                    `;
                    tbodyMats.appendChild(tr);
                }
            });
            
            if (tbodyMats.innerHTML === '') {
                tbodyMats.innerHTML = '<tr><td colspan="6" style="text-align: center; padding: 20px; color: #999;">Nenhum material alocado neste PEP</td></tr>';
            }
            
            // Preencher histórico
            const tbodyHist = document.getElementById('consultaPEPHistorico');
            tbodyHist.innerHTML = '';
            
            const historico = [];
            
            dados.saidas.filter(s => s.pep.id === pepId).forEach(s => {
                s.itens.forEach(item => {
                    historico.push({
                        data: s.data,
                        tipo: 'Entrega',
                        material: item.material,
                        qtd: item.qtd,
                        usuario: s.usuario
                    });
                });
            });
            
            dados.entradasDevolucao.filter(d => d.pep.id === pepId).forEach(d => {
                d.itens.forEach(item => {
                    historico.push({
                        data: d.data,
                        tipo: 'Devolução',
                        material: item.material,
                        qtd: item.qtd,
                        usuario: d.usuario
                    });
                });
            });
            
            historico.sort((a, b) => new Date(b.data) - new Date(a.data));
            
            historico.forEach(h => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${new Date(h.data).toLocaleString('pt-BR')}</td>
                    <td><span class="badge ${h.tipo === 'Entrega' ? 'badge-danger' : 'badge-warning'}">${h.tipo}</span></td>
                    <td>${h.material.codigo} - ${h.material.descricao}</td>
                    <td>${h.qtd} ${h.material.unidade}</td>
                    <td>${h.usuario}</td>
                `;
                tbodyHist.appendChild(tr);
            });
        }

        function exportarConsultaPEP() {
            const pepCodigo = document.getElementById('consultaPEPCodigo').textContent;
            let csv = 'Código,Descrição,Qtd. Entregue,Qtd. Devolvida,Saldo\n';
            
            const rows = document.getElementById('consultaPEPMateriais').getElementsByTagName('tr');
            Array.from(rows).forEach(row => {
                const cells = row.getElementsByTagName('td');
                if (cells.length >= 5) {
                    csv += `${cells[0].textContent},"${cells[1].textContent}",${cells[2].textContent},${cells[3].textContent},${cells[4].textContent}\n`;
                }
            });
            
            const blob = new Blob([csv], {type: 'text/csv;charset=utf-8;'});
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `pep_${pepCodigo}_materiais.csv`;
            link.click();
            
            showAlert('Dados exportados com sucesso!');
        }

        // Fechar modais ao clicar fora
        window.onclick = function(event) {
            const modal = document.getElementById('modalMovimentacao');
            if (event.target === modal) {
                fecharModalMovimentacao();
            }
        }
    </script>
</body>
